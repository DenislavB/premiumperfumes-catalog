generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  nameBg        String
  description   String   @db.Text
  descriptionBg String   @db.Text
  brand         String
  volume        String
  gender        String
  price         Float
  originalPrice Float?
  quantity      Int      @default(0)
  images        String[]
  notes         String   @default("")
  notesBg       String   @default("")
  variants      Json     @default("[]") // [{ size: "100ml", price: 35 }] — empty = single size

  featured      Boolean  @default(false)
  inPromotion   Boolean  @default(false)
  discountPct   Int?
  available     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PurchaseRequest {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  courier   String?  // "Speedy" | "Econt"
  address   String?  @db.Text
  message   String?  @db.Text
  items     Json
  promoCode String?  // code applied to this order
  discount  Float?   // discount amount in EUR
  status    String   @default("new")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SpinEntry {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  phone     String?
  prize     String
  code      String?  // generated promo code, if the prize is a discount
  marketing Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percent") // "percent" | "fixed" | "freebie"
  discountValue Float                          // 10 = 10% or 10€; 0 for freebie
  note          String?                        // label for freebie vouchers (e.g. "Безплатна доставка")
  source        String    @default("standard") // "wheel" | "standard"
  minOrder      Float?                         // minimum order total (EUR) to qualify
  expiresAt     DateTime?                      // optional expiry
  usageLimit    Int?                           // optional max total uses
  usageCount    Int       @default(0)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
}
