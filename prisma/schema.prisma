generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  nameBg        String
  description   String   @db.Text
  descriptionBg String   @db.Text
  brand         String
  volume        String
  gender        String
  price         Float
  originalPrice Float?
  quantity      Int      @default(0)
  images        String[]
  notes         String   @default("")
  notesBg       String   @default("")
  variants      Json     @default("[]") // [{ size: "100ml", price: 35 }] — empty = single size

  featured      Boolean  @default(false)
  inPromotion   Boolean  @default(false)
  discountPct   Int?
  available     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PurchaseRequest {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  courier   String?  // "Speedy" | "Econt"
  address   String?  @db.Text
  message   String?  @db.Text
  items     Json
  status    String   @default("new")
  createdAt DateTime @default(now())
}
